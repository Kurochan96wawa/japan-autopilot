# ============================================================
# これをコピーして .env を作る（ローカルテスト用）
# 本番(GitHub Actions)では、これらは GitHub の Secrets に登録する。
# .env は絶対にコミットしない（.gitignore 済み）。
# ============================================================

# --- LLM（どれか1つ。予算重視ならGEMINI無料枠） ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- 画像（無料）。Pexelsの無料APIキー ---
PEXELS_API_KEY=

# --- Pinterest（公式API v5） ---
PINTEREST_ACCESS_TOKEN=

# --- Threads（Meta公式API・任意。既定OFF） ---
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- Instagram（Meta Graph API・任意の補助。視覚再利用） ---
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# --- サイトURL（GitHub Pages） ---
SITE_BASE_URL=https://YOUR_GITHUB_USERNAME.github.io/japan-autopilot

# --- トークン自動更新（任意。無人運用を続けるなら推奨） ---
# GitHub Secretsへ新トークンを書き戻すためのPAT（repo権限）とリポジトリ
GH_PAT=
GH_REPO=YOUR_GITHUB_USERNAME/japan-autopilot
# Pinterestトークン更新用（アプリのID/Secretとrefresh token）
PINTEREST_REFRESH_TOKEN=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
